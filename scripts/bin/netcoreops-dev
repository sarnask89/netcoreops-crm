#!/usr/bin/env bash
set -euo pipefail

cd /home/sarna/netcoreops

mode="${1:-rtk}"
port="${2:-3000}"

case "$mode" in
  rtk)
    export NODE_OPTIONS="${NODE_OPTIONS:---max-old-space-size=3000}"
    exec rtk pnpm exec nuxt dev --host 0.0.0.0 --port "$port"
    ;;
  nortk)
    export NODE_OPTIONS="${NODE_OPTIONS:---max-old-space-size=2048}"
    exec pnpm exec nuxt dev --host 0.0.0.0 --port "$port"
    ;;
  *)
    echo "Usage: netcoreops-dev [rtk|nortk] [port]" >&2
    exit 64
    ;;
esac
