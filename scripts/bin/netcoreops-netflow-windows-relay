#!/usr/bin/env bash
set -euo pipefail

listen="${NETCOREOPS_NETFLOW_RELAY_LISTEN:-10.0.87.224}"
port="${NETCOREOPS_NETFLOW_PORT:-2055}"
forward="${NETCOREOPS_NETFLOW_RELAY_FORWARD:-127.0.0.1}"
ingest="${NETCOREOPS_NETFLOW_RELAY_INGEST_URL:-http://127.0.0.1:3000/api/netflow/ingest-aggregate}"
token="${NETCOREOPS_NETFLOW_INGEST_TOKEN:-local-netflow-ingest}"

script="$(wslpath -w /home/sarna/netcoreops/scripts/windows/netflow-udp-relay.ps1)"
log='C:\Users\xxx\AppData\Local\Temp\netcoreops-netflow-udp-relay.log'

exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script" -ListenAddress "$listen" -ListenPort "$port" -ForwardAddress "$forward" -ForwardPort "$port" -IngestUrl "$ingest" -IngestToken "$token" -LogPath "$log"
