#!/usr/bin/env bash
set -euo pipefail

cd /home/sarna/netcoreops
export PATH="/home/sarna/.local/bin:/home/sarna/.hermes/node/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/mnt/c/Program Files/nodejs:${PATH:-}"

mode="${1:-rtk}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$mode" in
  rtk)
    exec rtk pnpm exec tsx scripts/netflow-status.ts "$@"
    ;;
  nortk)
    exec pnpm exec tsx scripts/netflow-status.ts "$@"
    ;;
  *)
    echo "Usage: netcoreops-netflow-status [rtk|nortk] [inventoryId...]" >&2
    exit 2
    ;;
esac
