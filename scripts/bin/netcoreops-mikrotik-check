#!/usr/bin/env bash
set -euo pipefail

cd /home/sarna/netcoreops

mode="${1:-rtk}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$mode" in
  rtk)
    exec rtk pnpm exec tsx scripts/check-mikrotik-diagnostics.ts "$@"
    ;;
  nortk)
    exec pnpm exec tsx scripts/check-mikrotik-diagnostics.ts "$@"
    ;;
  *)
    echo "Usage: netcoreops-mikrotik-check [rtk|nortk] [inventoryId...]" >&2
    exit 2
    ;;
esac
