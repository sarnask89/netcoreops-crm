#!/usr/bin/env bash
set -euo pipefail

cd /home/sarna/netcoreops

mode="${1:-rtk}"

case "$mode" in
  rtk)
    rtk pnpm run db:import:sandomierz
    rtk pnpm run db:restrict:sandomierz
    ;;
  nortk)
    pnpm run db:import:sandomierz
    pnpm run db:restrict:sandomierz
    ;;
  *)
    echo "Usage: netcoreops-db-import-sandomierz [rtk|nortk]" >&2
    exit 64
    ;;
esac
