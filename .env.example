# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=
DATABASE_URL=postgresql://netcoreops:netcoreops@127.0.0.1:5432/netcoreops
NETCOREOPS_SECRET_KEY=replace-with-local-32-byte-secret
NETCOREOPS_AUTH_USERNAME=admin
NETCOREOPS_AUTH_PASSWORD=change-me
NETCOREOPS_AUTH_SESSION_SECRET=replace-with-local-session-secret
NETCOREOPS_NETFLOW_COLLECTOR=10.0.222.226:2055
NETCOREOPS_NETFLOW_BIND=0.0.0.0
NETCOREOPS_NETFLOW_PORT=2055
NETCOREOPS_NETFLOW_FLUSH_MS=10000
NETCOREOPS_NETFLOW_INGEST_TOKEN=change-me
